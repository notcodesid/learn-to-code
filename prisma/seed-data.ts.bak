fn test_tuples_and_arrays() {
    let info = (42i32, 'R', true);
    let (num, ch, flag) = info;
    assert_eq!(num, 42);
    assert_eq!(ch, 'R');
    assert_eq!(flag, true);

    let nums: [i32; 4] = [5, 10, 15, 20];
    assert_eq!(nums[2], 15);
    assert_eq!(nums.len(), 4);
}`,
