    println!("Iterating:");
    for (name, score) in &scores {
        println!("  {} scored {}", name, score);
    }
    
    println!("\nSorted by score:");
    let mut sorted: Vec<_> = scores.iter().collect();
    sorted.sort_by_key(|(_, score)| score);
    
    for (name, score) in sorted {
        println!("  {} scored {}", name, score);
    }
