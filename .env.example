# Database URL for Supabase PostgreSQL
# Get this from your Supabase project settings
DATABASE_URL="postgresql://postgres:your_password@db.your_project_id.supabase.co:5432/postgres"

# Supabase Configuration
# Get these from your Supabase project settings > API
SUPABASE_PROJECT_ID=your_supabase_project_id
NEXT_PUBLIC_SUPABASE_URL=https://your_project_id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional: Add your OpenAI API key for full AI mentor functionality
# Without it, the mentor uses a built-in fallback with hints and guidance
OPENAI_API_KEY=your_openai_api_key_here

# NextAuth configuration
NEXTAUTH_SECRET=your_nextauth_secret_here_generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth credentials
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Dodo Payments (fiat: cards, UPI)
# Get API key from https://dashboard.dodopayments.com/developer/api-keys
DODO_PAYMENTS_API_KEY=your_dodo_api_key_here
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_WEBHOOK_SECRET=your_dodo_webhook_secret_here
DODO_PRODUCT_ID_USD=prod_xxx_usd

# App URL for payment redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Paywall feature flags
PAYWALL_ENABLED=true
NEXT_PUBLIC_PAYWALL_ENABLED=true