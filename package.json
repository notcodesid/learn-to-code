{
  "name": "learn-to-code",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "bun --bun next dev --webpack",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "lint": "bun --bun eslint",
    "seed": "bun --bun tsx prisma/seed.ts",
    "seed:test-cases": "bun run scripts/seed-test-cases.ts",
    "seed:test-specs": "bun run scripts/seed-test-specs.ts"
  },
  "prisma": {
    "seed": "bun --bun tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/client": "^6",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-auth": "^4",
    "prisma": "^6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/dotenv": "^8.2.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
